<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="custom_paper_formate_report" model="report.paperformat">
        <field name="name">Custom Paper Formate Report</field>
        <field name="default" eval="False" />
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">30</field>
        <field name="margin_bottom">20</field>
        <field name="margin_left">7</field>
        <field name="margin_right">7</field>
        <field name="header_line" eval="False" />
        <field name="header_spacing">25</field>
        <field name="dpi">90</field>
    </record>

    <record id="action_purchase_order_template" model="ir.actions.report">
        <field name="name">Custom Purchase Order</field>
        <field name="model">purchase.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">nspl_custom_reports.custom_purchase_order_template</field>
        <field name="report_file">nspl_custom_reports.custom_purchase_order_template</field>
        <field name="print_report_name">'Purchase Order - %s' % object.name</field>
        <field name="paperformat_id" ref="nspl_custom_reports.custom_paper_formate_report" />
        <field name="binding_model_id" ref="purchase.model_purchase_order" />
        <field name="binding_type">report</field>
    </record>

    <template id="custom_purchase_order_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="nspl_custom_reports.report_custom_header">
                    <div class="page">

                        <!-- Title -->
                        <h2 style="text-align:center; margin-bottom: 3px;">Purchase Order</h2>

                        <!-- order details -->
                        <table style="width:100%; border-collapse: collapse; margin-bottom: 5px;">
                            <tr>
                                <td
                                    style="width:25%; padding: 4px; border: 1px solid black;">
                                    <strong>Order No:</strong>
                                </td>
                                <td
                                    style="width:25%; padding: 4px; border: 1px solid black;">
                                    <span t-field="o.name" />
                                </td>
                                <td
                                    style="width:25%; padding: 4px; border: 1px solid black;">
                                    <strong>Order Date :</strong>
                                </td>
                                <td
                                    style="width:25%; padding: 4px; border: 1px solid black;">
                                    <span t-field="o.date_order"
                                        t-options="{'format': 'dd/MM/yyyy'}" />
                                </td>
                            </tr>
                            <!-- Row 2 -->
                            <tr>
                                <td
                                    style="width:25%; padding: 4px; border: 1px solid black;">
                                    <strong>Due Date:</strong>
                                </td>
                                <td
                                    style="width:25%; padding: 4px; border: 1px solid black;">
                                    <span t-field="o.date_approve"
                                        t-options="{'format': 'dd/MM/yyyy'}" />
                                </td>
                                <td
                                    style="width:25%; padding: 4px; border: 1px solid black;">
                                    <strong>Place of supply:</strong>
                                </td>
                                <td
                                    style="width:25%; padding: 4px; border: 1px solid black;">
                                    <t t-if="o.company_id.state_id">
                                        <span
                                            t-esc="o.company_id.state_id.l10n_in_tin + ' - ' + o.company_id.state_id.name" />
                                    </t>
                                </td>
                            </tr>
                            <!-- Row 3 -->
                            <tr>
                                <td
                                    style="width:25%; padding: 4px; border: 1px solid black;">
                                    <strong>Reference :</strong>
                                </td>
                                <td colspan="3"
                                    style="width:25%; padding: 4px; border: 1px solid black;">
                                   
                                </td>
                            </tr>
                        </table>

                        <!-- ship and bill to -->
                        <table
                            style="width:100%; border-collapse: collapse; border: 1px solid black; margin-bottom: 8px;">
                            <tr>
                                <!-- Consignee (Ship to) -->
                                <td
                                    style="width:50%; vertical-align: top; padding: 10px; border: 1px solid black;">
                                    <strong>Consignee (Ship to):</strong>
                                    <br />
                                    <t t-set="consignee"
                                        t-value="o.dest_address_id or o.company_id.partner_id" />
                                    <strong>
                                        <span t-field="consignee.name" />
                                    </strong>
                                    <br />
                                    <span
                                        t-if="consignee.street" t-field="consignee.street" />
                                    <br />
                                    <span
                                        t-if="consignee.street2" t-field="consignee.street2" />
                                    <br />
                                    <span
                                        t-if="consignee.city" t-field="consignee.city" />, <span
                                        t-if="consignee.state_id" t-field="consignee.state_id.name" />
                                    <span
                                        t-if="consignee.country_id">, <span
                                            t-field="consignee.country_id" />
                                    </span>
                                    <span
                                        t-if="consignee.zip">- <span t-field="consignee.zip" /><br />
                                    </span>

                                    <t
                                        t-if="consignee.vat">
                                        <strong>GSTIN:</strong>
                                        <span t-field="consignee.vat" />
                                        <br />
                                    </t>
                                    <span
                                        t-if="consignee.phone">Ph: <span t-field="consignee.phone" />
                                    </span>
                                </td>

                                <!-- Buyer (Bill to) -->
                                <td
                                    style="width:50%; vertical-align: top; padding: 10px; border: 1px solid black;">
                                    <strong>Buyer (Bill to):</strong>
                                    <br />
                                    <strong>
                                        <span t-field="o.partner_id.name" />
                                    </strong>
                                    <br />
                                    <span
                                        t-if="o.partner_id.street" t-field="o.partner_id.street" />
                                    <br />
                                    <span
                                        t-if="o.partner_id.street2" t-field="o.partner_id.street2" />
                                    <br />
                                    <span
                                        t-if="o.partner_id.city" t-field="o.partner_id.city" />, <span
                                        t-if="o.partner_id.state_id"
                                        t-field="o.partner_id.state_id.name" />
                                    <span
                                        t-if="o.partner_id.country_id">, <span
                                            t-field="o.partner_id.country_id" />
                                    </span>
                                    <span
                                        t-if="o.partner_id.zip"> - <span t-field="o.partner_id.zip" />
                                    </span>
                                    <br />
                                    <t
                                        t-if="o.partner_id.vat">
                                        <strong>GSTIN:</strong>
                                        <span t-field="o.partner_id.vat" />
                                        <br />
                                    </t>
                                    <span
                                        t-if="o.partner_id.phone">Ph: <span
                                            t-field="o.partner_id.phone" />
                                    </span>
                                </td>
                            </tr>
                        </table>

                        <!-- order line table -->
                        <table class="table table-bordered"
                            style="width:100%; border-collapse: collapse; border: 1px solid black; margin-bottom: 7px;">
                            <thead>
                                <tr style="background-color: #f0f0f0;">
                                    <th
                                        style="padding: 4px; border: 1px solid black; text-align: center;">
                                        #</th>
                                    <th
                                        style="padding: 4px; border: 1px solid black; text-align: center;">Item
                                        Name
                                    </th>
                                    <th
                                        style="padding: 4px; border: 1px solid black; text-align: center;">HSN
                                        / SAC
                                    </th>
                                    <th
                                        style="padding: 4px; border: 1px solid black; text-align: center;">
                                        Quantity
                                    </th>
                                    <th
                                        style="padding: 4px; border: 1px solid black; text-align: center;">Price
                                        / Unit
                                    </th>
                                    <th
                                        style="padding: 4px; border: 1px solid black; text-align: center;">
                                        GST
                                    </th>
                                    <th
                                        style="padding: 4px; border: 1px solid black; text-align: center;">
                                        Amount
                                    </th>

                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="sr_no" t-value="1" />

                                <t t-foreach="o.order_line" t-as="line">
                                    <t t-if="not line.display_type">
                                        <tr>
                                            <!-- SR NO -->
                                            <td style="text-align:center;">
                                                <span t-esc="sr_no" />
                                            </td>

                                            <!-- ITEM NAME -->
                                            <td style="text-align:left;">
                                                <span t-field="line.name" />
                                            </td>

                                            <!-- HSN -->
                                            <td style="text-align:center;">
                                                <span t-field="line.product_id.l10n_in_hsn_code" />
                                            </td>

                                            <!-- QTY -->
                                            <td style="text-align:right;">
                                                <span t-field="line.product_qty" />
                                            </td>

                                            <!-- PRICE -->
                                            <td style="text-align:right;">
                                                <span t-field="line.price_unit" />
                                            </td>

                                            <!-- GST -->
                                            <td style="text-align:right; white-space: nowrap;">
                                                <t t-set="tax_percent"
                                                    t-value="sum(t.amount for t in line.tax_ids)" />
                                                <t t-set="tax_amt"
                                                    t-value="line.price_subtotal * tax_percent / 100" />

                                                <span
                                                    t-esc="o.currency_id.symbol + ' %.2f' % tax_amt" />
                                                <span t-esc="' (' + str(int(tax_percent)) + '%)'" />
                                            </td>

                                            <!-- AMOUNT -->
                                            <td style="text-align:right;">
                                                <span t-field="line.price_subtotal" />
                                            </td>
                                        </tr>

                                        <t t-set="sr_no" t-value="sr_no + 1" />
                                    </t>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr style="background-color: #f0f0f0; font-weight: bold;">
                                    <td colspan="2"
                                        style="padding: 4px; border: 1px solid black; text-align: right;">
                                        Total
                                    </td>
                                    <td style="padding: 4px; border: 1px solid black;" />
                                    <td
                                        style="text-align: right; padding: 4px; border: 1px solid black;">
                                        <span
                                            t-esc="'%.2f' % sum(line.product_qty for line in o.order_line if not line.display_type)" />
                                    </td>

                                    <td style="padding: 4px; border: 1px solid black;"></td>

                                    <!-- TAX TOTAL -->
                                    <td
                                        style="text-align: right; padding: 4px; border: 1px solid black;">
                                        <t t-set="gst_total"
                                            t-value="sum(
                                                (line.price_subtotal * sum(t.amount for t in line.tax_ids) / 100)
                                                for line in o.order_line if not line.display_type)" />

                                        <span t-esc="'%.2f' % gst_total" />
                                    </td>
                                    <td
                                        style="text-align: right; padding: 4px; border: 1px solid black;">
                                        <span t-field="o.amount_untaxed" />
                                    </td>

                                </tr>
                            </tfoot>
                        </table>

                        <!-- Amount in Words + Tax Summary -->
                        <table
                            style="width:100%; border-collapse: collapse; border: 1px solid black;">
                            <tr>
                                <td
                                    style="width:55%; padding: 8px;">
                                    <strong>Total Invoice Amount (<span t-esc="o.currency_id.name" />)
                                        in Words:</strong>
                                    <br />
                                    <br />
                                    <span t-esc="o.currency_id.amount_to_text(o.amount_total)" />
                                </td>
                                <td
                                    style="width:45%; padding: 4px;  vertical-align: top; line-height: 3px;">
                                    <div id="total">
                                        <div class="ms-auto">
                                            <table
                                                class="o_total_table table table-borderless avoid-page-break-inside border border-0">

                                                <t t-if="o.tax_totals"
                                                    t-call="account.document_tax_totals">
                                                    <t t-set="tax_totals" t-value="o.tax_totals" />
                                                    <t t-set="currency" t-value="o.currency_id" />
                                                </t>
                                            </table>
                                        </div>
                                    </div>
                                    <t
                                        t-if="o.tax_totals and o.tax_totals.get('display_in_company_currency')">
                                        <t t-set="tax_totals" t-value="o.tax_totals" />
                                        <t
                                            t-call="account.document_tax_totals_company_currency_template" />
                                    </t>
                                    <t t-else="">
                                        <div />
                                    </t>
                                </td>
                            </tr>
                        </table>

                        <!-- hsn table -->
                        <t t-if="o.company_id.account_fiscal_country_id.code == 'IN'">
                            <t t-set="hsn_summary" t-value="o._l10n_in_get_hsn_summary_table()" />
                            <t t-if="hsn_summary">
                                <div name="l10n_in_hsn_summary" class="mt-3"
                                    style="page-break-inside: avoid font-size: 12px !important;">
                                    <table class="table table-sm table-borderless col-6">
                                        <thead>
                                            <th>HSN/SAC</th>
                                            <th class="text-end">Taxable Value</th>
                                            <th class="text-end">Rate %</th>
                                            <th class="text-end" t-if="hsn_summary['has_gst']">
                                                SGST</th>
                                            <th class="text-end" t-if="hsn_summary['has_gst']">
                                                CGST</th>
                                            <th class="text-end" t-if="hsn_summary['has_igst']">
                                                IGST</th>
                                            <th class="text-end" t-if="hsn_summary['has_cess']">
                                                CESS</th>
                                        </thead>
                                        <tr t-foreach="hsn_summary['items']" t-as="item">
                                            <td t-esc="item['l10n_in_hsn_code']" />
                                            <td class="text-end">
                                                <span t-esc="item['amount_untaxed']"
                                                    t-options="{'widget': 'monetary', 'display_currency': o.currency_id}" />
                                            </td>
                                            <td class="text-end" t-esc="item['rate']" />

                                            <td class="text-end" t-if="hsn_summary['has_gst']">
                                                <span t-esc="item['tax_amount_sgst']"
                                                    t-options="{'widget': 'monetary', 'display_currency': o.currency_id}" />
                                            </td>
                                            <td class="text-end" t-if="hsn_summary['has_gst']">
                                                <span t-esc="item['tax_amount_cgst']"
                                                    t-options="{'widget': 'monetary', 'display_currency': o.currency_id}" />
                                            </td>
                                            <td class="text-end" t-if="hsn_summary['has_igst']">
                                                <span t-esc="item['tax_amount_igst']"
                                                    t-options="{'widget': 'monetary', 'display_currency': o.currency_id}" />
                                            </td>
                                            <td class="text-end" t-if="hsn_summary['has_cess']">
                                                <span t-esc="item['tax_amount_cess']"
                                                    t-options="{'widget': 'monetary', 'display_currency': o.currency_id}" />
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                            </t>
                        </t>

                        <!-- Left: Terms & Conditions -->
                        <table
                            style="width:100%; border-collapse: collapse; border: 1px solid black; margin-top: 5px; margin-bottom: 5px;">
                            <tr>
                                <td
                                    style="padding:10px; border: 1px solid black; width: 50%; vertical-align: top;">
                                    <strong>Terms &amp; Conditions:</strong>
                                    <br />


                                    <t t-if="o.note">
                                        <span t-field="o.note" />
                                    </t>
                                    <t t-else="">
                                        <span>No terms defined</span>
                                    </t>
                                </td>

                                <td
                                    style="padding:7px; border: 1px solid black; width: 50%; text-align: center; vertical-align: middle;">
                                    <div>
                                        <span>
                                            FOR AVINYA TECHNOLOGY SOLUTIONS
                                        </span>
                                    </div>
                                    <div
                                        style="position: relative; display: inline-block; width: 180px; height: 70px;">

                                        <t t-if="o.company_id.invoice_sign">
                                            <img
                                                t-att-src="'data:image/png;base64,%s' % o.company_id.invoice_sign.decode('utf-8')"
                                                style="
                                                        position: absolute;
                                                        bottom: 5px;
                                                        left: 10px;
                                                        max-height: 60px;
                                                        max-width: 160px;
                                                        z-index: 1;
                                                        opacity: 0.95;"
                                                alt="Signature" />
                                        </t>

                                        <!-- Seal (overlapping + rotated) -->
                                        <!-- <t t-if="o.company_id.company_seal">
                                            <img
                                                t-att-src="'data:image/png;base64,%s' % o.company_id.company_seal.decode('utf-8')"
                                                style="
                                                        position: absolute;
                                                        bottom: 20px;
                                                        left: 40px;
                                                        height: auto;
                                                        width: 200px;
                                                        z-index: 2;
                                                        opacity: 0.85;
                                                        transform: rotate(-12deg);"
                                                alt="Company Seal" />
                                        </t> -->
                                    </div>
                                    <br />
                                    <t t-if="o.company_id.invoice_signatory">
                                        <strong>
                                            <span t-field="o.company_id.invoice_signatory.name" />
                                        </strong>
                                        <br />
                                    </t>
                                    <strong>Authorised Signatory</strong>
                                </td>
                            </tr>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>