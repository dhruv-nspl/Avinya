<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="custom_paper_formate_report" model="report.paperformat">
        <field name="name">Custom Paper Formate Report</field>
        <field name="default" eval="False" />
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">30</field>
        <field name="margin_bottom">20</field>
        <field name="margin_left">7</field>
        <field name="margin_right">7</field>
        <field name="header_line" eval="False" />
        <field name="header_spacing">25</field>
        <field name="dpi">90</field>
    </record>

    <record id="action_commercial_invoice_template" model="ir.actions.report">
        <field name="name">Custom Commercial Invoice</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">nspl_custom_reports.custom_commercial_invoice_template</field>
        <field name="report_file">nspl_custom_reports.custom_commercial_invoice_template</field>
        <field name="print_report_name">'Commercial Invoice - %s' % object.name</field>
        <field name="paperformat_id" ref="nspl_custom_reports.custom_paper_formate_report" />
        <field name="binding_model_id" ref="account.model_account_move" />
        <field name="binding_type">report</field>
    </record>

    <template id="custom_commercial_invoice_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="nspl_custom_reports.report_custom_header">
                    <div class="page">
                        <!-- Title -->
                        <h2 style="text-align:center; margin-bottom: 3px;">Commercial Invoice</h2>

                        <!-- INVOICE DETAIALS -->
                        <t t-set="sale_order"
                            t-value="env['sale.order'].search([('name','=', o.invoice_origin)], limit=1)" />
                        <table style="width:100%; border-collapse: collapse; margin-bottom: 5px;">
                            <tr>
                                <td
                                    style="width:25%; padding: 4px; border: 1px solid black;">
                                    <strong>Export Invoice No:</strong>
                                </td>
                                <td
                                    style="width:25%; padding: 4px; border: 1px solid black;">
                                    <span t-field="o.name" />
                                </td>
                                <td
                                    style="width:25%; padding: 4px; border: 1px solid black;">
                                    <strong>Invoice Date :</strong>
                                </td>
                                <td
                                    style="width:25%; padding: 4px; border: 1px solid black;">
                                    <span t-field="o.invoice_date"
                                        t-options="{'format': 'dd/MM/yyyy'}" />
                                </td>
                            </tr>
                            <!-- Row 2 -->
                            <tr>
                                <td
                                    style="width:25%; padding: 4px; border: 1px solid black;">
                                    <strong>Exporter Ref:</strong>
                                </td>
                                <td
                                    style="width:25%; padding: 4px; border: 1px solid black;">
                                    <span t-field="o.company_id.iec_no" />
                                </td>
                                <td
                                    style="width:25%; padding: 4px; border: 1px solid black;">
                                    <strong>LUT No:</strong>
                                </td>
                                <td
                                    style="width:25%; padding: 4px; border: 1px solid black;">
                                    <span t-field="o.company_id.lut_no" />

                                </td>
                            </tr>
                            <!-- Row 3 -->
                            <tr t-if="sale_order">
                                <td style="width:25%; padding: 4px; border: 1px solid black;">
                                    <strong>Proforma Inv No:</strong>
                                </td>
                                <td style="width:25%; padding: 4px; border: 1px solid black;">
                                    <span t-esc="sale_order.name" />
                                </td>

                                <td style="width:25%; padding: 4px; border: 1px solid black;">
                                    <strong>Proforma Inv Date:</strong>
                                </td>
                                <td style="width:25%; padding: 4px; border: 1px solid black;">
                                    <span t-field="sale_order.date_order"
                                        t-options="{'format': 'dd/MM/yyyy'}" />
                                </td>
                            </tr>
                        </table>

                        <!-- ship and bill -->
                        <table
                            style="width:100%; border-collapse: collapse; border: 1px solid black; margin-bottom: 8px;">
                            <tr>
                                <!-- Consignee (Ship to) -->
                                <td
                                    style="width:50%; vertical-align: top; padding: 10px; border: 1px solid black;">
                                    <strong>Consignee (Ship to):</strong>
                                    <br />
                                    <t t-set="consignee"
                                        t-value="o.partner_shipping_id" />
                                    <strong>
                                        <span t-field="consignee.name" />
                                    </strong>
                                    <br />
                                    <span
                                        t-if="consignee.street" t-field="consignee.street" />
                                    <br />
                                    <span
                                        t-if="consignee.street2" t-field="consignee.street2" />
                                    <br />
                                    <span
                                        t-if="consignee.city" t-field="consignee.city" />, <span
                                        t-if="consignee.state_id" t-field="consignee.state_id.name" />
                                    <span
                                        t-if="consignee.country_id">, <span
                                            t-field="consignee.country_id" />
                                    </span>
                                    <span
                                        t-if="consignee.zip">- <span t-field="consignee.zip" /><br />
                                    </span>

                                    <t
                                        t-if="consignee.vat">
                                        <strong>GSTIN:</strong>
                                        <span t-field="consignee.vat" />
                                        <br />
                                    </t>
                                    <span
                                        t-if="consignee.phone">Ph: <span t-field="consignee.phone" />
                                    </span>
                                </td>

                                <!-- Buyer (Bill to) -->
                                <td
                                    style="width:50%; vertical-align: top; padding: 10px; border: 1px solid black;">
                                    <strong>Buyer (Bill to):</strong>
                                    <br />
                                    <strong>
                                        <span t-field="o.partner_id.name" />
                                    </strong>
                                    <br />
                                    <span
                                        t-if="o.partner_id.street" t-field="o.partner_id.street" />
                                    <br />
                                    <span
                                        t-if="o.partner_id.street2" t-field="o.partner_id.street2" />
                                    <br />
                                    <span
                                        t-if="o.partner_id.city" t-field="o.partner_id.city" />, <span
                                        t-if="o.partner_id.state_id"
                                        t-field="o.partner_id.state_id.name" />
                                    <span
                                        t-if="o.partner_id.country_id">, <span
                                            t-field="o.partner_id.country_id" />
                                    </span>
                                    <span
                                        t-if="o.partner_id.zip"> - <span t-field="o.partner_id.zip" />
                                    </span>
                                    <br />
                                    <t
                                        t-if="o.partner_id.vat">
                                        <strong>GSTIN:</strong>
                                        <span t-field="o.partner_id.vat" />
                                        <br />
                                    </t>
                                    <span
                                        t-if="o.partner_id.phone">Ph: <span
                                            t-field="o.partner_id.phone" />
                                    </span>
                                </td>
                            </tr>
                        </table>

                        <!-- Dispatch details -->
                        <table style="width:100%; border-collapse: collapse; margin-bottom: 5px;">
                            <tr>
                                <td style="padding: 5px; border: 1px solid black; width:25%;">
                                    <strong>Pre-Carriage By:</strong>
                                    <span t-if="o.dispatch_through" t-field="o.dispatch_through" />
                                </td>
                                <td style="padding: 5px; border: 1px solid black; width:25%;">

                                    <!-- ROAD -->
                                    <t t-if="o.dispatch_through == 'road'">
                                        <strong>LR Receipt:</strong>
                                        <span t-if="o.lr_number" t-field="o.lr_number" />
                                    </t>
                                    <!-- SEA -->
                                    <t t-elif="o.dispatch_through == 'sea'">
                                        <strong>BL No:</strong>
                                        <span t-if="o.bl_number" t-field="o.bl_number" />
                                    </t>
                                    <!-- AIR -->
                                    <t t-elif="o.dispatch_through == 'air'">
                                        <strong>Air Way Bill:</strong>
                                        <span t-if="o.awb_number" t-field="o.awb_number" />
                                    </t>
                                    <!-- RAIL -->
                                    <t t-elif="o.dispatch_through == 'rail'">
                                        <strong>Train No:</strong>
                                        <span t-if="o.train_no" t-field="o.train_no" />
                                    </t>
                                </td>
                                <td style="padding: 5px; border: 1px solid black; width:25%;">

                                    <!-- ROAD -->
                                    <t t-if="o.dispatch_through == 'road'">
                                        <strong>From:</strong>
                                        <span t-if="o.location_from" t-field="o.location_from" />
                                    </t>

                                    <!-- SEA -->
                                    <t t-elif="o.dispatch_through == 'sea'">
                                        <strong>Port Of Loading:</strong>
                                        <span t-if="o.port_of_loading" t-field="o.port_of_loading" />
                                    </t>

                                    <!-- AIR -->
                                    <t t-elif="o.dispatch_through == 'air'">
                                        <strong>Airport from:</strong>
                                        <span t-if="o.airport_from" t-field="o.airport_from" />
                                    </t>

                                    <!-- RAIL -->
                                    <t t-elif="o.dispatch_through == 'rail'">
                                        <strong>Station From:</strong>
                                        <span t-if="o.station_from" t-field="o.station_from" />
                                    </t>

                                </td>

                                <td style="padding: 5px; border: 1px solid black; width:25%;">

                                    <!-- ROAD -->
                                    <t t-if="o.dispatch_through == 'road'">
                                        <strong>To:</strong>
                                        <span t-if="o.location_to" t-field="o.location_to" />
                                    </t>
                                    <!-- SEA -->
                                    <t t-elif="o.dispatch_through == 'sea'">
                                        <strong>Port Of Discharge:</strong>
                                        <span t-if="o.port_of_discharge"
                                            t-field="o.port_of_discharge" />
                                    </t>
                                    <!-- AIR -->
                                    <t t-elif="o.dispatch_through == 'air'">
                                        <strong>Airport from:</strong>
                                        <span t-if="o.airport_from" t-field="o.airport_from" />
                                    </t>
                                    <!-- RAIL -->
                                    <t t-elif="o.dispatch_through == 'rail'">
                                        <strong>Station To:</strong>
                                        <span t-if="o.airport_to" t-field="o.airport_to" />
                                    </t>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 5px; border: 1px solid black; width:25%;">
                                    <strong>Delivery Doc No:</strong>
                                    <span t-if="o.dispatch_doc_no" t-field="o.dispatch_doc_no" />
                                </td>

                                <td style="padding: 5px; border: 1px solid black; width:25%;">
                                    <strong>Final Destination:</strong>
                                    <span t-if="o.incoterm_location"
                                        t-field="o.incoterm_location" />
                                </td>

                                <td colspan="2"
                                    style="padding: 5px; border: 1px solid black; width:25%;">
                                    <strong>Terms Of Payment :</strong>
                                    <span t-if="o.invoice_payment_term_id" t-field="o.invoice_payment_term_id" />
                                </td>
                            </tr>
                            <tr>
                                <td colspan="4"
                                    style="padding: 5px; border: 1px solid black; width:25%;">
                                    <strong>Terms Of Delivery:</strong>
                                    <span t-if="o.term_of_delivery" t-field="o.term_of_delivery" />
                                </td>
                            </tr>
                        </table>

                        <!-- Order Line table -->
                        <table class="table table-bordered"
                            style="width:100%; border-collapse: collapse; border: 1px solid black; margin-bottom: 7px;">
                            <thead>
                                <tr style="background-color: #f0f0f0;">
                                    <th
                                        style="padding: 4px; border: 1px solid black; text-align: center;">
                                        #</th>
                                    <th
                                        style="padding: 4px; border: 1px solid black; text-align: center;">
                                        NO.&amp; PACKAGES
                                    </th>
                                    <th
                                        style="padding: 4px; border: 1px solid black; text-align: center;">DESCRIPTION
                                        OF GOODS
                                    </th>
                                    <th
                                        style="padding: 4px; border: 1px solid black; text-align: center;">HSN
                                        / SAC
                                    </th>
                                    <th
                                        style="padding: 4px; border: 1px solid black; text-align: center;">
                                        Unit
                                    </th>
                                    <th
                                        style="padding: 4px; border: 1px solid black; text-align: center;">
                                        Quantity
                                    </th>
                                    <th
                                        style="padding: 4px; border: 1px solid black; text-align: center;">Rate
                                        (<span t-esc="o.currency_id.symbol" />) </th>

                                    <th
                                        style="padding: 4px; border: 1px solid black; text-align: center;">
                                        Amount
                                    </th>

                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="sr_no" t-value="1" />
                                <t t-foreach="o.invoice_line_ids" t-as="line">
                                    <t t-if="line.display_type">
                                        <tr>
                                            <!-- SR NO -->
                                            <td style="text-align:center;">
                                                <span t-esc="sr_no" />
                                            </td>

                                            <td style="text-align:left;">
                                            </td>

                                            <!-- ITEM NAME -->
                                            <td style="text-align:left;">
                                                <span t-field="line.name" />
                                            </td>

                                            <!-- HSN -->
                                            <td style="text-align:center;">
                                                <span t-field="line.product_id.l10n_in_hsn_code" />
                                            </td>
                                            <!-- UNIT -->
                                            <td style="text-align:center;">
                                                <span t-field="line.product_uom_id" />
                                            </td>

                                            <!-- QTY -->
                                            <td style="text-align:right;">
                                                <span t-field="line.quantity" />
                                            </td>

                                            <!-- PRICE -->
                                            <td style="text-align:right;">
                                                <span t-field="line.price_unit" />
                                            </td>

                                            <!-- AMOUNT -->
                                            <td style="text-align:right;">
                                                <span t-field="line.price_subtotal" />
                                            </td>
                                        </tr>
                                        <t t-set="sr_no" t-value="sr_no + 1" />
                                    </t>
                                </t>
                            </tbody>
                            <tfoot>

                                <tr style="background-color: #f0f0f0; font-weight: bold;">
                                    <td colspan="3"
                                        style="padding: 4px; border: 1px solid black; text-align: right;">
                                        Total
                                    </td>
                                    <td style="padding: 4px; border: 1px solid black;" />
                                    <td style="padding: 4px; border: 1px solid black;" />
                                    <td
                                        style="text-align: right; padding: 4px; border: 1px solid black;">
                                        <span
                                            t-esc="'%.2f' % sum(line.quantity for line in o.invoice_line_ids if line.display_type)" />
                                    </td>

                                    <td style="padding: 4px; border: 1px solid black;"></td>

                                    <td
                                        style="text-align: right; padding: 4px; border: 1px solid black;">
                                        <span t-field="o.amount_untaxed" />
                                    </td>

                                </tr>
                            </tfoot>
                        </table>

                        <!-- gross nt  -->
                        <table style="width:100%; border-collapse: collapse; margin-bottom: 5px;">
                            <tr>
                                <td style="width:25%; padding: 4px; border: 1px solid black;">
                                    <strong>NET WT :</strong>
                                </td>
                                <td style="width:25%; padding: 4px; border: 1px solid black;"></td>
                                <td style="width:25%; padding: 4px; border: 1px solid black;">
                                    <strong>P.O. No. :</strong>
                                </td>
                                <td style="width:25%; padding: 4px; border: 1px solid black;"> </td>
                            </tr>
                            <tr>
                                <td style="width:25%; padding: 4px; border: 1px solid black;">
                                    <strong>GROSS WT :</strong>
                                </td>
                                <td style="width:25%; padding: 4px; border: 1px solid black;"></td>
                                <td style="width:25%; padding: 4px; border: 1px solid black;">
                                    <strong>Date :</strong>
                                </td>
                                <td style="width:25%; padding: 4px; border: 1px solid black;"> </td>
                            </tr>
                        </table>

                        <!-- Amount in Words + Tax Summary -->
                        <table
                            style="width:100%; border-collapse: collapse; border: 1px solid black;">
                            <tr>
                                <td style=" padding: 8px; font-size:14px;">
                                    <div>
                                        <strong>Total Invoice Amount (<span
                                                t-esc="o.currency_id.name" />) in Words:</strong>
                                        <span t-esc="o.currency_id.amount_to_text(o.amount_total)" />
                                    </div>
                                    <!-- <br /> -->
                                    <div>
                                        <strong>Note :</strong>
                                         <span> Pan No: <t
                                                t-esc="o.company_id.l10n_in_pan_entity_id.name or ''" /></span>
                                        ,
                                        <span> GSTIN No: <t
                                                t-esc="o.company_id.vat or 'N/A'" />
                                        </span>
                                        ,
                                        <span> IGST
                                        PAYMENT: N.A.</span>, <span> ACCESSORY STATUS: NO ACCESSORY</span>
                                    </div>
                                </td>

                            </tr>
                        </table>

                        <table
                            style="width:100%; border-collapse: collapse; border: 1px solid black; margin-top: 5px; margin-bottom: 5px;">
                            <tr>
                                <td
                                    style="padding:10px; border: 1px solid black; width: 50%; vertical-align: top;">
                                    <strong>Bank Details:</strong>
                                    <br />
                                    <br />
                                    <t t-if="o.partner_bank_id">
                                        <t t-set="bank" t-value="o.partner_bank_id" />
                                        <strong>Bank :</strong>
                                        <span t-field="bank.bank_id.name" />
                                        <br />
                                        <strong>A/C No :</strong>
                                        <span t-field="bank.acc_number" />
                                        <br />
                                        <strong>IFSC :</strong>
                                        <span t-field="bank.bank_id.bank_ifsc_code" />
                                        <br />
                                        <strong>AD Code :</strong>
                                        <span t-field="bank.bank_id.bank_ad_code" />
                                        <br />
                                    </t>
                                    <t t-else="">
                                        <span>Bank details not configured</span>
                                    </t>
                                </td>
                                <td
                                    style="padding:7px; border: 1px solid black; width: 50%; text-align: center; vertical-align: middle;">
                                    <div>
                                        <span>
                                            FOR AVINYA TECHNOLOGY SOLUTIONS
                                        </span>
                                    </div>
                                    <div
                                        style="position: relative; display: inline-block; width: 180px; height: 70px;">

                                        <!-- Signature (base layer) -->
                                        <t t-if="o.company_id.invoice_sign">
                                            <img
                                                t-att-src="'data:image/png;base64,%s' % o.company_id.invoice_sign.decode('utf-8')"
                                                style="
                                                        position: absolute;
                                                        bottom: 5px;
                                                        left: 10px;
                                                        max-height: 60px;
                                                        max-width: 160px;
                                                        z-index: 1;
                                                        opacity: 0.95;"
                                                alt="Signature" />
                                        </t>

                                        <!-- Seal (overlapping + rotated) -->
                                        <!-- <t t-if="o.company_id.company_seal">
                                            <img
                                                t-att-src="'data:image/png;base64,%s' % o.company_id.company_seal.decode('utf-8')"
                                                style="
                                                        position: absolute;
                                                        bottom: 20px;
                                                        left: 40px;
                                                        height: auto;
                                                        width: 200px;
                                                        z-index: 2;
                                                        opacity: 0.85;
                                                        transform: rotate(-12deg);"
                                                alt="Company Seal" />
                                        </t> -->
                                    </div>
                                    <br />
                                    <t t-if="o.company_id.invoice_signatory">
                                        <strong>
                                            <span t-field="o.company_id.invoice_signatory.name" />
                                        </strong>
                                        <br />
                                    </t>

                                    <strong>Authorised Signatory</strong>

                                </td>
                            </tr>
                        </table>

                        <!-- DECLARATION: -->
                        <table
                            style="width:100%; border-collapse: collapse; border: 1px solid black;">
                            <tr>
                                <td style=" padding: 8px;  font-size:14px;">
                                    <div>
                                        <strong>DECLARATION :</strong>
                                        <br />
                                        <span>WE DECLARE THAT THIS INVOICE SHOWS THE ACTUAL PRICE OF
                                            THE GOODS DESCRIBED &amp; THAT ALL PARTICULARS ARE TRUE
                                            &amp;
                                            CORRECT</span>
                                    </div>
                                </td>

                            </tr>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>