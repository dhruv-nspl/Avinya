<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="custom_account_move_view_form" model="ir.ui.view">
        <field name="name">custom.account.move.view.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <xpath expr="//group[@id='other_tab_group']" position="inside">

                <group string="Dispatch Details" invisible="move_type != 'out_invoice'">
                    <field name="dispatch_doc_no"/>
                    <field name="term_of_delivery"/>
                    <field name="dispatch_through"/>
                </group>

                <group string="🚢 Sea Details" invisible="move_type != 'out_invoice' or dispatch_through != 'sea'">
                    <group>
                        <field name="port_of_loading"/>
                        <field name="bl_number"/>
                        <field name="container_no"/>
                    </group>
                    <group>
                        <field name="port_of_discharge"/>
                        <field name="container_type"/>
                        <field name="vessel_name"/>
                    </group>
                </group>

                <group string="✈️ Air Details" invisible="move_type != 'out_invoice' or dispatch_through != 'air'">
                    <group>
                        <field name="airport_from"/>
                        <field name="awb_number"/>
                        <field name="airline"/>
                    </group>
                    <group>
                        <field name="airport_to"/>
                        <field name="flight_no"/>
                        <field name="cargo_type"/>
                    </group>
                </group>

                <group string="🚚 Road Details" invisible="move_type != 'out_invoice' or dispatch_through != 'road'">
                    <group>
                        <field name="lr_number"/>
                        <field name="location_from"/>
                        <field name="driver_name"/>
                    </group>
                    <group>
                        <field name="vehicle_no"/>
                        <field name="location_to"/>
                        <field name="driver_phone"/>
                    </group>
                </group>

                <group string="🚆 Rail Details" invisible="move_type != 'out_invoice' or dispatch_through != 'rail'">
                    <group>
                        <field name="station_from"/>
                        <field name="train_no"/>
                        <field name="railway_receipt"/>
                    </group>
                    <group>
                        <field name="station_to"/>
                        <field name="wagon_no"/>
                    </group>
                </group>

            </xpath>
        </field>
    </record>
</odoo>