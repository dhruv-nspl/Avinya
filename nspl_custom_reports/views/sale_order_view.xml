<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="custom_view_sale_order_form" model="ir.ui.view">
        <field name="name">custom.view.sale.order.form</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form" />
        <field name="arch" type="xml">
            <xpath
                expr="//form/sheet/group[@name='sale_header']/group[@name='order_details']/field[@name='payment_term_id']"
                position="after">
                <field name="price_term_id" />
                <field name="insurance_id" />
            </xpath>
        </field>
    </record>


    <record id="action_sale_order_view_inherit" model="ir.actions.act_window">
        <field name="name">Price Term</field>
        <field name="res_model">price.term</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_price_term"
        name="Price Terms"
        action="action_sale_order_view_inherit"
        parent="sale.menu_sales_config"
        sequence="40" />

</odoo>