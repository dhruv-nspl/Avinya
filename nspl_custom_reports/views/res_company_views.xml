<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="custom_res_company_form" model="ir.ui.view">
        <field name="name">custom.res.company.form</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form" />
        <field name="arch" type="xml">

            <xpath expr="//form[1]/sheet[1]/notebook[1]" position="inside">
                <page string="Export Info" name="export_info">
                    <group>
                        <field name="iec_no" />
                        <field name="lut_no" />
                    </group>
                </page>
                <page string="Signature Authority" name="tax_details">
                    <group>
                        <group name="inv_sign">
                            <field name="invoice_signatory" />
                            <field name="invoice_sign" widget="image"
                                options="{'size': [200,'']}" />
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>