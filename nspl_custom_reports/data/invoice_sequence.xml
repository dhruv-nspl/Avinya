<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Normal Invoice -->
    <record id="seq_invoice_normal_custom" model="ir.sequence">
        <field name="name">Normal Invoice Sequence</field>
        <field name="code">invoice.normal.custom</field>
        <field name="prefix">ATS_</field>
        <field name="padding">4</field>
        <field name="number_next_actual">1</field>
    </record>

    <!-- Export Invoice -->
    <record id="seq_invoice_export_custom" model="ir.sequence">
        <field name="name">Export Invoice Sequence</field>
        <field name="code">invoice.export.custom</field>
        <field name="prefix">ATS_EI_</field>
        <field name="padding">3</field>
        <field name="number_next_actual">1</field>
    </record>
</odoo>