<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="report_invoice_document_inherit_sequence" inherit_id="account.report_invoice_document">
        <xpath expr="//table[hasclass('table')]//tr//th[@name='th_description']"
               position="before">
            <th name="th_sequence" class="text-start">#</th>
        </xpath>
        <xpath expr="//tbody//tr//td"
               position="before">
            <td name="td_sequence">
                <span t-esc="line.sequence_no"/>
            </td>
        </xpath>
        <xpath expr="//div[@name='comment']" position="after"> 
            <t t-if="o.company_id.partner_id.bank_ids">
                <div style="margin-top:20px;">
                    <strong style="font-size:14px;">Bank Details:</strong>
                    <t t-foreach="o.company_id.partner_id.bank_ids" t-as="bank">
                        <div style="margin-top:5px;">
                            <strong t-field="bank.bank_id"/>
                            <br/>
                            Account Name: <span t-field="o.company_id"/>
                            <br/>
                            Account Number: <span t-field="bank.acc_number"/>
                            <br/>
                            IFSC / BIC: <span t-field="bank.bank_id.bic"/>
                            <br/>
                            Branch: <span t-field="bank.bank_id.city"/>
                        </div>
                    </t>
                </div>
            </t>
        </xpath>
    </template>
</odoo>
