<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--    Inherited form view of account move-->
    <record id="view_move_form_inherited" model="ir.ui.view">
        <field name="name">
            account.move.view.form.inherit.order.line.sequences
        </field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_line_ids']//list//field[@name='product_id']"
                   position="before">
                <field name="sequence_no"/>
            </xpath>
        </field>
    </record>
    
</odoo>
