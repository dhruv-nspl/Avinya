<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--        Inherited sale report sale order document-->
    <template id="sales_report" inherit_id="sale.report_saleorder_document">
        <xpath expr="//table[hasclass('table')]//tr//th[@name='th_description']"
               position="before">
            <th name="th_sequence" class="text-start">#</th>
        </xpath>
        <xpath expr="//tbody[@class='sale_tbody']//tr//td[@name='td_product_name']"
               position="before">
            <td name="td_sequence" class="text-start">
                <span t-esc="line.sequence_number"/>
            </td>
        </xpath>
        <xpath expr="//div[@class='page']" position="inside"> 
            <div style="border:1px solid #ddd; padding:10px; margin-top:20px;">
                <strong style="font-size:14px;">Bank Details</strong>
                <hr style="margin:5px 0;"/>
                <table style="width:100%; font-size:12px;">
                    <tr>
                        <td style="width:30%;"><strong>Bank Name</strong></td>
                        <td><span t-field="bank.bank_id"/></td>
                    </tr>
                    <tr>
                        <td><strong>Account Number</strong></td>
                        <td><span t-field="bank.acc_number"/></td>
                    </tr>
                    <tr>
                        <td><strong>IFSC Code</strong></td>
                        <td><span t-field="bank.bank_id.bic"/></td>
                    </tr>
                    <tr>
                        <td><strong>Account Holder</strong></td>
                        <td><span t-field="o.company_id"/></td>
                    </tr>
                </table>
            </div>
        </xpath>
    </template>
</odoo>
