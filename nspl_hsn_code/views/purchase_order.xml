<odoo>
    <record id="purchase_order_line_form_new_fields_added" model="ir.ui.view">
        <field name="name">purchase.order.line.form.new.fields</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='products']//field[@name='order_line']//field[@name='product_id']"
                   position="after">
                <field name="hsn_code"/>
            </xpath>
        </field>
    </record>
</odoo>
