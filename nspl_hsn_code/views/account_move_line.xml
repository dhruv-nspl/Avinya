<odoo>
    <record id="account_move_line_form_new_fields_added" model="ir.ui.view">
        <field name="name">account.move .line.form.new.fields</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='invoice_tab']//field[@name='invoice_line_ids']//field[@name='product_id']"
                   position="after">
                <field name="hsn_code"/>
            </xpath>
        </field>
    </record>
</odoo>
