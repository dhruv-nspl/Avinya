<odoo>
    <record id="sale_order_line_form_new_fields_added" model="ir.ui.view">
        <field name="name">sale.order.line.form.new.fields</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='order_lines']//field[@name='order_line']//field[@name='product_template_id']"
                   position="after">
                <field name="hsn_code"/>
            </xpath>
        </field>
    </record>

</odoo>
