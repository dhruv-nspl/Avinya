<odoo>
    <template id="report_purchaseorder_document_inherit_hsn" inherit_id="purchase.report_purchasequotation_document">
        <xpath expr="//th[@name='th_description']" position="after">
            <th name="th_hsn_code" class="text-start">HSN Code</th>
        </xpath>

        <xpath expr="//td[@id='product']" position="after">
            <td name="td_hsn_code" class="text-start">
                <span t-field="order_line.hsn_code"/>
            </td>
        </xpath>
    </template>
</odoo>
